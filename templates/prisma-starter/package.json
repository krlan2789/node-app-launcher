{
    "name": "express-prisma-starter",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "postinstall": "prisma generate",
        "predeploy": "npm run build",
        "deploy": "tsc",
        "watch": "ts-node --watch src/index.ts"
    },
    "dependencies": {
        "@prisma/client": "^5.10.2",
        "express": "^5.2.1",
        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "prisma": "^7.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    }
}