{
    "name": "express-minimal-starter",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "run-p type-check \"build-only {@}\" --",
        "predeploy": "npm run build",
        "deploy": "tsc",
        "dev": "nodemon",
        "start": "node dist/index.js",
        "watch": "ts-node --watch src/index.ts"
    },
    "dependencies": {
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    }
}